# Copy this file to ".env" in the same folder and fill in real values.
# .env is git-ignored — never commit real credentials.

# Required — path to your Firebase service-account JSON key
# (Firebase Console -> Project settings -> Service accounts -> Generate new private key)
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Optional — only needed if you want the 303 sample product photos
# uploaded to Cloudinary automatically. Leave blank to seed products
# without photos and add images later from the admin panel.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=thangamalar-products
