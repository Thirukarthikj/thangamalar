rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── PRODUCTS ──────────────────────────────────────────────
    // Public site: anyone can read products marked active.
    // Admin panel: only a signed-in admin (Firebase Auth) can read
    // every product (active or hidden) and can create/update/delete.
    match /products/{productId} {
      allow read: if resource.data.active == true || request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    // ── ENQUIRIES (product enquiry modal + contact form) ────────
    // Anyone can submit an enquiry; only a signed-in admin can read
    // or manage them. Nobody can edit/delete someone else's enquiry.
    match /enquiries/{enquiryId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // ── NEWSLETTER SIGN-UPS ──────────────────────────────────────
    match /newsletter/{entryId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
